# Install pre-commit hooks (skip if already installed)
if [ -d .git ] && ! grep -qE 'prek|pre-commit' .git/hooks/pre-commit 2>/dev/null; then
  if command -v prek &>/dev/null; then
    log_status "installing prek hooks"
    prek install
  elif command -v pre-commit &>/dev/null; then
    log_status "installing pre-commit hooks"
    pre-commit install
  fi
fi
