{
  "inputs": [
    {
      "type": "promptString",
      "id": "mcp-api-key",
      "description": "ISUCON MCP Server API Key (run: azd env get-value ISUCON_MCP_API_KEY)",
      "password": true
    },
    {
      "type": "promptString",
      "id": "mcp-fqdn",
      "description": "ISUCON MCP Server FQDN (run: azd env get-value ISUCON_MCP_FQDN)"
    }
  ],
  "servers": {
    "isucon13-mcp": {
      "type": "http",
      "url": "https://${input:mcp-fqdn}/mcp",
      "headers": {
        "Authorization": "Bearer ${input:mcp-api-key}"
      }
    }
  }
}
